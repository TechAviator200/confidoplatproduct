{
  "name": "riverbend-voice-agent-phase1",
  "private": true,
  "version": "0.1.0",
  "description": "Deterministic scheduling rules, tool contracts, HTTP adapter, and regression tests for the Riverbend Gastroenterology voice agent.",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test $(find dist/tests -name '*.test.js')",
    "dev:server": "tsx watch server/index.ts",
    "server": "npm run build && node dist/server/index.js",
    "test:server": "npm run build && node --test $(find dist/server/tests -name '*.test.js')"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
